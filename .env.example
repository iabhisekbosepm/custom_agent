# API configuration (OpenRouter, OpenAI, Ollama, LM Studio — any OpenAI-compatible API)
OPENAI_API_KEY=sk-or-v1-your-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
MODEL=openrouter/auto

# Logging
LOG_LEVEL=info

# Query loop
MAX_TURNS=20

# Context compaction — max estimated tokens before compaction triggers (default: 120000)
CONTEXT_BUDGET=120000
