{
  "name": "custom-agents",
  "version": "0.1.0",
  "description": "Custom AI coding assistant runtime",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "custom-agents": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
